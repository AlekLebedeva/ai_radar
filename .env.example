# Grafana
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin

# Admin Auth
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin

# LLM API
OPENAI_API_KEY=sk-...
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=GigaChat-3-Ultra
