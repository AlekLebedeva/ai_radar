# AI Radar Configuration
DEBUG=true
ADMIN_STATIC_PATH=static/admin
PARSER_INTERVAL_HOURS=48

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/ai_radar
DASHBOARD_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/ai_radar
APP_MODE=prod

# API Collectors
